{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/Expected333/BP-Mods-Registry/schema/index.schema.json",
  "title": "BrokeProtocol Mods Registry Index",
  "description": "Index agrégé généré par la GitHub Action, servi via GitHub Pages.",
  "type": "object",
  "required": ["schema_version", "generated_at", "mods"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "registry_url": { "type": "string", "format": "uri" },
    "mods": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "version", "author", "repo", "download_url", "sha256"],
        "properties": {
          "name": { "type": "string" },
          "version": { "type": "string" },
          "author": { "type": "string" },
          "description": { "type": "string" },
          "repo": { "type": "string", "format": "uri" },
          "homepage": { "type": "string", "format": "uri" },
          "download_url": { "type": "string", "format": "uri" },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "size_bytes": { "type": "integer" },
          "published_at": { "type": "string", "format": "date-time" },
          "stars": { "type": "integer" },
          "dependencies": { "type": "array", "items": { "type": "string" } },
          "min_modloader_version": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
